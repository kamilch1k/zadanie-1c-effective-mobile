///////////////////////////////////////////////////////////////////////////////
// Вспомогательный загрузчик данных из раздела «Пример данных» задания.
// Не входит в состав обработки — нужен только чтобы быстро воссоздать в базе
// ровно тот пример, на котором построены «Пример 1» и «Пример 2».
//
// Как воспользоваться (по желанию, для проверки):
//   1. Временно добавить на форму команду и вызвать ЗаполнитьТестовыеДанныеНаСервере().
//   2. Запустить обработку в режиме «Предприятие» и нажать кнопку один раз.
//   3. Данные готовы — «Заполнить нужное»/«Удалить лишнее» дадут результат из примеров.
//
// Идемпотентно: повторный запуск не плодит дубли (договоры ищутся по
// наименованию, ведомости — по номеру, записи регистра — по измерениям).
// Требование к базе: у документа «Ведомость» отключена Автонумерация (номера задаём явно).
///////////////////////////////////////////////////////////////////////////////

&НаСервере
Процедура ЗаполнитьТестовыеДанныеНаСервере()

	// --- Справочник «Договоры»: Наименование -> Ссылка ---
	Дог = Новый Соответствие;
	СоздатьДоговор(Дог, "Договор_1",  Истина, Дата(2025,1,1));
	СоздатьДоговор(Дог, "Договор_2",  Ложь,   Дата(2025,1,1));
	СоздатьДоговор(Дог, "Договор_3",  Истина, Дата(2025,2,1));
	СоздатьДоговор(Дог, "Договор_4",  Истина, Дата(2025,2,1));
	СоздатьДоговор(Дог, "Договор_5",  Ложь,   Дата(2025,3,1));
	СоздатьДоговор(Дог, "Договор_6",  Ложь,   Дата(2025,3,15));
	СоздатьДоговор(Дог, "Договор_7",  Истина, Дата(2025,3,15));
	СоздатьДоговор(Дог, "Договор_8",  Истина, Дата(2025,4,1));
	СоздатьДоговор(Дог, "Договор_9",  Истина, Дата(2025,5,1));
	СоздатьДоговор(Дог, "Договор_10", Ложь,   Дата(2025,6,1));
	СоздатьДоговор(Дог, "Договор_11", Ложь,   Дата(2025,7,10));
	СоздатьДоговор(Дог, "Договор_12", Ложь,   Дата(2025,8,1));
	// Договоры с ведущим нулём — только в ЛР04-002048 (в примере-справочнике их нет).
	СоздатьДоговор(Дог, "Договор_09", Ложь,   Дата(2025,5,1));
	СоздатьДоговор(Дог, "Договор_08", Ложь,   Дата(2025,4,1));
	СоздатьДоговор(Дог, "Договор_07", Ложь,   Дата(2025,3,15));

	// --- Документы «Ведомость» + табличная часть (в порядке строк) ---
	СоздатьВедомость("БТ02-000016", Дата(2025,4,1,8,16,32), Дог, "Договор_1,Договор_2");
	СоздатьВедомость("БТ02-000032", Дата(2025,5,2,16,0,4),  Дог, "Договор_4,Договор_5,Договор_3,Договор_7");
	СоздатьВедомость("БТ02-000064", Дата(2025,5,16,4,2,1),  Дог, ""); // без строк — есть только в регистре
	СоздатьВедомость("БТ02-000128", Дата(2025,6,1,0,32,0),  Дог, "Договор_7,Договор_8,Договор_9");
	СоздатьВедомость("ЛР04-000256", Дата(2025,4,10,2,2,2),  Дог, "Договор_1,Договор_3,Договор_2,Договор_8,Договор_7,Договор_5,Договор_6,Договор_4");
	СоздатьВедомость("ЛР04-000512", Дата(2025,4,20,16,4,8), Дог, "Договор_12");
	СоздатьВедомость("ЛР04-001024", Дата(2025,5,12,1,1,16), Дог, "Договор_3,Договор_11");
	СоздатьВедомость("ЛР04-002048", Дата(2025,8,1,8,8,4),   Дог, "Договор_09,Договор_10,Договор_11,Договор_08,Договор_07");

	// --- Регистр «ИсторияСтатусовДокументов» ---
	Вед = ВедомостиПоНомерам();
	П = Перечисления.СтатусыДокументов;
	СтатусЗапись(Вед, Дата(2025,4,1,10,10,10),  "БТ02-000016", П.Создан);
	СтатусЗапись(Вед, Дата(2025,4,1,11,11,11),  "БТ02-000016", П.Заблокирован);
	СтатусЗапись(Вед, Дата(2025,5,2,16,0,16),   "БТ02-000032", П.Внутренний);
	СтатусЗапись(Вед, Дата(2025,5,19,12,12,12), "БТ02-000016", П.Акцептован);
	СтатусЗапись(Вед, Дата(2025,5,19,12,12,12), "БТ02-000064", П.Акцептован);
	СтатусЗапись(Вед, Дата(2025,6,1,1,11,10),   "БТ02-000128", П.Акцептован);
	СтатусЗапись(Вед, Дата(2025,4,11,10,4,26),  "ЛР04-000256", П.Заблокирован);
	СтатусЗапись(Вед, Дата(2025,6,1,1,23,45),   "БТ02-000128", П.Внутренний);
	СтатусЗапись(Вед, Дата(2025,4,10,10,4,25),  "ЛР04-000256", П.Создан);
	СтатусЗапись(Вед, Дата(2025,4,10,14,0,41),  "ЛР04-000256", П.Заблокирован);
	СтатусЗапись(Вед, Дата(2025,5,17,17,18,19), "БТ02-000064", П.Заблокирован);
	СтатусЗапись(Вед, Дата(2025,4,11,10,4,25),  "ЛР04-000256", П.Акцептован);
	СтатусЗапись(Вед, Дата(2025,8,2,23,59,59),  "ЛР04-002048", П.Заблокирован);
	СтатусЗапись(Вед, Дата(2025,5,12,2,2,32),   "ЛР04-001024", П.Создан);
	СтатусЗапись(Вед, Дата(2025,5,12,20,20,23), "ЛР04-001024", П.Акцептован);
	СтатусЗапись(Вед, Дата(2025,8,2,0,0,0),     "ЛР04-002048", П.Создан);
	СтатусЗапись(Вед, Дата(2025,8,3,12,0,0),    "ЛР04-002048", П.Внутренний);

	Сообщить("Тестовые данные загружены: договоров 15, ведомостей 8, записей истории 17.");

КонецПроцедуры

&НаСервере
Процедура СоздатьДоговор(Дог, Наименование, Активен, НачалоДействия)
	Ссылка = Справочники.Договоры.НайтиПоНаименованию(Наименование, Истина);
	Об = ?(Ссылка.Пустая(), Справочники.Договоры.СоздатьЭлемент(), Ссылка.ПолучитьОбъект());
	Об.Наименование   = Наименование;
	Об.Активен        = Активен;
	Об.НачалоДействия = НачалоДействия;
	Об.Записать();
	Дог.Вставить(Наименование, Об.Ссылка);
КонецПроцедуры

&НаСервере
Процедура СоздатьВедомость(Номер, ДатаДок, Дог, СписокДоговоров)
	Ссылка = Документы.Ведомость.НайтиПоНомеру(Номер);
	Док = ?(Ссылка.Пустая(), Документы.Ведомость.СоздатьДокумент(), Ссылка.ПолучитьОбъект());
	Док.Номер = Номер;
	Док.Дата  = ДатаДок;
	Док.Договоры.Очистить();
	Если Не ПустаяСтрока(СписокДоговоров) Тогда
		Для Каждого ИмяДог Из СтрРазделить(СписокДоговоров, ",", Ложь) Цикл
			Док.Договоры.Добавить().Договор = Дог[СокрЛП(ИмяДог)];
		КонецЦикла;
	КонецЕсли;
	Док.Записать(РежимЗаписиДокумента.Запись);
КонецПроцедуры

&НаСервере
Функция ВедомостиПоНомерам()
	Соответствие = Новый Соответствие;
	// NB: метод нельзя вызывать прямо на «Новый Запрос(...)» — сначала переменная.
	Запрос = Новый Запрос("ВЫБРАТЬ Ссылка, Номер ИЗ Документ.Ведомость");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Соответствие.Вставить(СокрЛП(Выборка.Номер), Выборка.Ссылка);
	КонецЦикла;
	Возврат Соответствие;
КонецФункции

&НаСервере
Процедура СтатусЗапись(Вед, ДатаЗаписи, Номер, Статус)
	ВедомостьСсылка = Вед[Номер];
	Если ВедомостьСсылка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	МЗ = РегистрыСведений.ИсторияСтатусовДокументов.СоздатьМенеджерЗаписи();
	МЗ.ДатаЗаписи = ДатаЗаписи;
	МЗ.Документ   = ВедомостьСсылка;
	МЗ.Статус     = Статус;
	МЗ.Записать(Истина);
КонецПроцедуры
