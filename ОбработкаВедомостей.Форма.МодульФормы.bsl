///////////////////////////////////////////////////////////////////////////////
// Внешняя обработка «ОбработкаВедомостей». Модуль ОСНОВНОЙ формы.
// Платформа 8.3.25, управляемые формы.
//
// Команды формы:
//   • «Заполнить нужное» — отобрать ведомости, у которых дата начала действия
//     первого активного договора в ТЧ равна/не равна минимальной/максимальной
//     дате начала действия договора в этой же ТЧ, и вывести их в таблицу.
//   • «Удалить лишнее»   — удалить ведомости с чётным количеством договоров
//     и сообщить пользователю номера удалённых документов.
//
// Вариативные условия (сноски 1, 2 задания) вынесены на форму — переключатели
// «ВариантСравнения» (равна/не равна) и «ВариантЭкстремума» (минимальной/максимальной),
// что покрывает все 4 комбинации.
//
// Индивидуальный дополнительный функционал (кандидат — Камиль Гильфанов):
//   (1) дата отправки решения 04.07 → диапазон 1–10 → при заполнении исключаем
//       ведомости, у которых день даты равен дню текущей даты;
//   (2) пол мужской → условное оформление создаётся ПРОГРАММНО
//       (см. НастроитьУсловноеОформление);
//   (3) длина фамилии «Гильфанов» = 9 (диапазон 8–9) → результат «Удалить лишнее»
//       выводится «создав и открыв произвольную форму» (см. ФормаСообщения).
// Как поменять эти варианты, если исходные данные другие — см. README.md.
///////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Значения переключателей по умолчанию: «равна» + «минимальной» (Пример 1 задания).
	ВариантСравнения  = 0; // 0 = «равна»,        1 = «не равна»
	ВариантЭкстремума = 0; // 0 = «минимальной»,  1 = «максимальной»

	// (2) Пол кандидата мужской ⇒ условное оформление настраиваем из кода.
	НастроитьУсловноеОформление();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаполнитьНужное(Команда)
	ЗаполнитьТаблицуВедомостейНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЛишнее(Команда)
	УдалитьЛишниеВедомости();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// «Заполнить нужное».
// Вся выборка и агрегация выполняются одним пакетным запросом на сервере
// (минимум обращений клиент ↔ сервер; группировки и соединения — средствами СУБД).
// Тонкий отбор по вариативному условию делается в цикле: набор строк заведомо
// мал (одна строка на ведомость), поэтому отдельный проход по нему дешевле, чем
// перестроение запроса под каждую из 4 комбинаций переключателей.
&НаСервере
Процедура ЗаполнитьТаблицуВедомостейНаСервере()

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СтрокиДоговоров.Ссылка КАК Ведомость,
	|	СтрокиДоговоров.НомерСтроки КАК НомерСтроки,
	|	СтрокиДоговоров.Договор.Активен КАК ДоговорАктивен,
	|	СтрокиДоговоров.Договор.НачалоДействия КАК НачалоДействия
	|ПОМЕСТИТЬ ВТ_СтрокиДоговоров
	|ИЗ
	|	Документ.Ведомость.Договоры КАК СтрокиДоговоров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Границы дат и количество договоров по каждой ведомости.
	|ВЫБРАТЬ
	|	Строки.Ведомость КАК Ведомость,
	|	МИНИМУМ(Строки.НачалоДействия) КАК МинНачалоДействия,
	|	МАКСИМУМ(Строки.НачалоДействия) КАК МаксНачалоДействия,
	|	КОЛИЧЕСТВО(*) КАК КоличествоДоговоров
	|ПОМЕСТИТЬ ВТ_Границы
	|ИЗ
	|	ВТ_СтрокиДоговоров КАК Строки
	|СГРУППИРОВАТЬ ПО
	|	Строки.Ведомость
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Номер строки первого активного договора (минимальный НомерСтроки среди активных).
	|ВЫБРАТЬ
	|	Строки.Ведомость КАК Ведомость,
	|	МИНИМУМ(Строки.НомерСтроки) КАК НомерСтроки
	|ПОМЕСТИТЬ ВТ_ПервыйАктивный
	|ИЗ
	|	ВТ_СтрокиДоговоров КАК Строки
	|ГДЕ
	|	Строки.ДоговорАктивен
	|СГРУППИРОВАТЬ ПО
	|	Строки.Ведомость
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Дата начала действия этого первого активного договора.
	|ВЫБРАТЬ
	|	ПервыйАктивный.Ведомость КАК Ведомость,
	|	Строки.НачалоДействия КАК ДатаПервогоАктивного
	|ПОМЕСТИТЬ ВТ_ДатаПервогоАктивного
	|ИЗ
	|	ВТ_ПервыйАктивный КАК ПервыйАктивный
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СтрокиДоговоров КАК Строки
	|		ПО ПервыйАктивный.Ведомость = Строки.Ведомость
	|			И ПервыйАктивный.НомерСтроки = Строки.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Максимальная дата записи в истории статусов по каждой ведомости.
	|// ВЫРАЗИТЬ отсекает записи по другим типам документов составного измерения.
	|ВЫБРАТЬ
	|	История.Документ КАК Ведомость,
	|	МАКСИМУМ(История.ДатаЗаписи) КАК МаксДатаЗаписи
	|ПОМЕСТИТЬ ВТ_МаксДатаСтатуса
	|ИЗ
	|	РегистрСведений.ИсторияСтатусовДокументов КАК История
	|ГДЕ
	|	ВЫРАЗИТЬ(История.Документ КАК Документ.Ведомость) ЕСТЬ НЕ NULL
	|СГРУППИРОВАТЬ ПО
	|	История.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Последний статус = статус записи с максимальной датой.
	|// МАКСИМУМ(Статус) — детерминированный tie-break на случай совпадения ДатаЗаписи
	|// у одной ведомости (в исходных данных таких совпадений нет).
	|ВЫБРАТЬ
	|	МаксДата.Ведомость КАК Ведомость,
	|	МАКСИМУМ(История.Статус) КАК ПоследнийСтатус
	|ПОМЕСТИТЬ ВТ_ПоследнийСтатус
	|ИЗ
	|	ВТ_МаксДатаСтатуса КАК МаксДата
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияСтатусовДокументов КАК История
	|		ПО История.Документ = МаксДата.Ведомость
	|			И История.ДатаЗаписи = МаксДата.МаксДатаЗаписи
	|СГРУППИРОВАТЬ ПО
	|	МаксДата.Ведомость
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|// Итог: одна строка на ведомость. Только ведомости, где ЕСТЬ активный договор
	|// (ВНУТРЕННЕЕ СОЕДИНЕНИЕ с ВТ_ДатаПервогоАктивного). Сразу упорядочено по дате.
	|ВЫБРАТЬ
	|	Границы.Ведомость КАК Ведомость,
	|	Границы.Ведомость.Номер КАК Номер,
	|	Границы.Ведомость.Дата КАК ДатаВедомости,
	|	Границы.КоличествоДоговоров КАК КоличествоДоговоров,
	|	Границы.МинНачалоДействия КАК МинНачалоДействия,
	|	Границы.МаксНачалоДействия КАК МаксНачалоДействия,
	|	ДатаАктивного.ДатаПервогоАктивного КАК ДатаПервогоАктивного,
	|	ПоследнийСтатус.ПоследнийСтатус КАК ПоследнийСтатус
	|ИЗ
	|	ВТ_Границы КАК Границы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ДатаПервогоАктивного КАК ДатаАктивного
	|		ПО ДатаАктивного.Ведомость = Границы.Ведомость
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПоследнийСтатус КАК ПоследнийСтатус
	|		ПО ПоследнийСтатус.Ведомость = Границы.Ведомость
	|УПОРЯДОЧИТЬ ПО
	|	ДатаВедомости"; // «упорядочить ведомости по возрастанию даты документов»

	Выборка = Запрос.Выполнить().Выбрать();

	ТаблицаВедомостей.Очистить();

	// (1) Дата отправки решения 04.07 (диапазон 1–10): при заполнении исключаем
	// ведомости, у которых день даты равен дню текущей даты.
	//   • для диапазона 11–20 было бы: День(ДатаВедомости) % 2 = 0 (день чётный);
	//   • для диапазона 21–31 было бы: Месяц(ДатаВедомости) % 2 = 1 (месяц нечётный).
	ТекущийДень = День(ТекущаяДата());

	Пока Выборка.Следующий() Цикл

		// Вариативное условие (сноски 1, 2 задания).
		Если Не ВедомостьПодходитПоДатеАктивного(Выборка) Тогда
			Продолжить;
		КонецЕсли;

		// (1) Индивидуальное исключение по дню даты.
		Если День(Выборка.ДатаВедомости) = ТекущийДень Тогда
			Продолжить;
		КонецЕсли;

		НоваяСтрока = ТаблицаВедомостей.Добавить();
		НоваяСтрока.Ведомость           = Выборка.Ведомость;
		НоваяСтрока.Номер               = Выборка.Номер;
		НоваяСтрока.ДатаВедомости       = Выборка.ДатаВедомости;
		НоваяСтрока.КоличествоДоговоров = Выборка.КоличествоДоговоров;
		НоваяСтрока.ПоследнийСтатус     = Выборка.ПоследнийСтатус;

	КонецЦикла;

КонецПроцедуры

// Вариативное условие отбора (сноски 1, 2 задания): дата первого активного
// договора «равна / не равна» «минимальной / максимальной» дате в этой ТЧ.
&НаСервере
Функция ВедомостьПодходитПоДатеАктивного(Выборка)

	ЭталоннаяДата = ?(ВариантЭкстремума = 0, Выборка.МинНачалоДействия, Выборка.МаксНачалоДействия);
	ДатыСовпадают = (Выборка.ДатаПервогоАктивного = ЭталоннаяДата);

	Возврат ?(ВариантСравнения = 0, ДатыСовпадают, Не ДатыСовпадают);

КонецФункции

// (2) Программное условное оформление (пол кандидата — мужской).
// Строки, у которых последний статус ведомости = «Акцептован», подсвечиваются
// светло-зелёным. Поля оформления не указываем ⇒ выделяется вся строка.
&НаСервере
Процедура НастроитьУсловноеОформление()

	Элемент = УсловноеОформление.Элементы.Добавить();

	Отбор = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("ТаблицаВедомостей.ПоследнийСтатус");
	Отбор.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.ПравоеЗначение = Перечисления.СтатусыДокументов.Акцептован;

	// Светло-зелёный (подобран под примеры задания; при необходимости меняется).
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", Новый Цвет(221, 235, 199));

КонецПроцедуры

// «Удалить лишнее».
// Удаляет из таблицы формы ведомости с чётным количеством договоров.
// Всё нужное (Номер, КоличествоДоговоров) уже лежит в таблице формы, поэтому
// обращение к серверу не требуется — команда полностью клиентская.
&НаКлиенте
Процедура УдалитьЛишниеВедомости()

	УдаленныеНомера = Новый СписокЗначений;

	// Идём с конца, чтобы безопасно удалять по индексу.
	Индекс = ТаблицаВедомостей.Количество() - 1;
	Пока Индекс >= 0 Цикл
		СтрокаТЗ = ТаблицаВедомостей[Индекс];
		Если СтрокаТЗ.КоличествоДоговоров % 2 = 0 Тогда
			УдаленныеНомера.Добавить(СтрокаТЗ.Номер);
			ТаблицаВедомостей.Удалить(Индекс);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;

	// «сортировка — по возрастанию номера ведомости» (номер — строка с префиксом).
	УдаленныеНомера.СортироватьПоЗначению(НаправлениеСортировки.Возр);

	// (3) Длина фамилии 8–9 ⇒ выводим результат в отдельной (произвольной) форме.
	ПоказатьРезультатВФорме(ТекстОбУдалении(УдаленныеНомера));

КонецПроцедуры

// Формирует строку вида «Удалено документов: 3 (БТ02-000256, БТ02-000512, ЛР04-000128).»
&НаКлиенте
Функция ТекстОбУдалении(УдаленныеНомера)

	Если УдаленныеНомера.Количество() = 0 Тогда
		Возврат "Удалено документов: 0.";
	КонецЕсли;

	Номера = Новый Массив;
	Для Каждого ЭлементСписка Из УдаленныеНомера Цикл
		Номера.Добавить(ЭлементСписка.Значение);
	КонецЦикла;

	Возврат "Удалено документов: " + УдаленныеНомера.Количество()
		+ " (" + СтрСоединить(Номера, ", ") + ").";

КонецФункции

// (3) Открывает произвольную форму этой же обработки с текстом результата.
&НаКлиенте
Процедура ПоказатьРезультатВФорме(Текст)
	ОткрытьФорму(ИмяФормыСообщения(), Новый Структура("Текст", Текст), ЭтаФорма);
КонецПроцедуры

// Полное имя вспомогательной формы этой же внешней обработки.
// Собираем из имени текущей формы (например «ВнешняяОбработка.ОбработкаВедомостей.Форма.Форма»),
// заменяя последний сегмент. Не зависит от того, под каким именем обработка
// подключена в конкретной базе. Fallback: вернуть строку-константу с именем формы.
&НаКлиенте
Функция ИмяФормыСообщения()
	ЧастиИмени = СтрРазделить(ЭтаФорма.ИмяФормы, ".");
	ЧастиИмени[ЧастиИмени.ВГраница()] = "ФормаСообщения";
	Возврат СтрСоединить(ЧастиИмени, ".");
КонецФункции

#КонецОбласти
